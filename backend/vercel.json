{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ],
  "env": {
    "FLASK_ENV": "production",
    "JWT_SECRET_KEY": "dummy-jwt-secret-for-vercel-deployment",
    "ADMIN_ROUTE_SECRET": "dummy-admin-route-secret",
    "SECRET_KEY": "dummy-secret-key-for-vercel",
    "DATABASE_URL": "sqlite:///tmp/instaloop.db"
  }
}
